  <property name="styleSheet">
   <string notr="true">/* Fondo general del central widget */
#centralwidget {
    background-color: #e6f1f8;
    background-position: center center;
    background-repeat: no-repeat;
}


/* QLabel */
QLabel {
    color: #002b45;
    font-size: 9pt;
    padding: 4px 6px;
    background: transparent;
}

/* QTabWidget y pestañas */
QTabWidget {
    background-color: #e6f1f8;
    border: none;
}

QTabWidget::pane {
    border: 1px solid #005577;
    background: #f8fbfd;
    border-radius: 6px;
}


QTabBar::tab {
    background: #c6e4f8;
    border: 1px solid #005577;
    padding: 6px 12px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    color: #002b45;
}

QTabBar::tab:selected {
    background: #ffffff;
    font-weight: bold;
    border-bottom: none;
}

QTabBar::tab:hover {
    background: #ddeefc;
}

/* QStatusBar */
QStatusBar {
    background-color: #d3e6f0;
    border-top: 1px solid #005577;
    color: #003865;
}

/* QPushButton */
QPushButton {
    background-color: #6fb1fc;
    color: white;
    border: 1px solid #005577;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 10pt;
}

QPushButton:hover {
    background-color: #a8d4ff;
}

QPushButton:pressed {
    background-color: #4c97d2;
}

QPushButton:disabled {
    background-color: #cccccc;
    color: #888888;
}

/* QTextEdit */
QTextEdit {
    background-color: #ffffff;
    color: #003865;
    border: 1px solid #005577;
    border-radius: 4px;
   padding: 6px;
}


/* QLineEdit */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #005577;
    color: #003865;
    padding: 4px;
    border-radius: 4px;
    text-align: center;
}

/* QComboBox */
QComboBox {
    background-color: #ffffff;
    border: 1px solid #6fb1fc;
    border-radius: 4px;
    padding: 4px;
    font-size: 10pt;
}

QComboBox:hover {
    background-color: #f0f9ff;
}

QComboBox::drop-down {
    border-left: 1px solid #6fb1fc;
    background-color: #6fb1fc;
    width: 20px;
}
/* QGroupBox (opcional si usás) */
QGroupBox {
    font-weight: bold;
    color: #003865;
}


/* QTableView */
QTableView {
    background-color: #ffffff;
    gridline-color: #cccccc;
    color: #003865;
    font-size: 10pt;
}

QHeaderView::section {
    background-color: #3d7da6;
    color: white;
    font-weight: bold;
}

QTableView::item:selected {
    background: #cce8f7;
    border: 1px solid #3d7da6;
}

/* Scrollbars */
QScrollBar:vertical, QScrollBar:horizontal {
    background: #e0f0f9;
}

QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: #6fb1fc;
}


</string>
